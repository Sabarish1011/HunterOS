# Application
APP_NAME=HunterOS
APP_ENV=development
APP_DEBUG=true
API_V1_PREFIX=/api/v1
LOG_LEVEL=INFO

# Server
HOST=0.0.0.0
PORT=8000

# PostgreSQL (localhost for native dev; Docker Compose overrides to "postgres")
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=hunteros
POSTGRES_PASSWORD=hunteros
POSTGRES_DB=hunteros
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10

# Redis (localhost for native dev; Docker Compose overrides to "redis")
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_KEY_PREFIX=hunteros

# Qdrant (localhost for native dev; Docker Compose overrides to "qdrant")
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_GRPC_PORT=6334
QDRANT_COLLECTION_PREFIX=hunteros_
QDRANT_VECTOR_SIZE=384

# CORS
CORS_ORIGINS=http://localhost:3000
